---
import Background from "@/components/Background.astro";
import type { Meta } from "@/config/landing.interface";
import "@fontsource-variable/rubik";

interface Props {
  meta: Meta;
}

const { meta } = Astro.props;

const ldJson = JSON.stringify(meta.ldJson);
---

<!doctype html>
<html
  class="scrollbar-thin scrollbar-thumb-black scrollbar-track-transparent scroll-smooth"
  lang={meta.lang ?? "en"}
>
  <head>
    <meta charset={meta.charset ?? "UTF-8"} />
    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={import.meta.env.SITE} />
    <script is:inline type="application/ld+json" set:html={ldJson} />
  </head>
  <body class="bg-white">
    <Background />
    <slot />
    <a
      href="https://wa.me/243997007071"
      target="_blank"
      rel="noopener noreferrer"
      class="whatsapp-float"
      aria-label="Chat on WhatsApp"
      title="Chat on WhatsApp"
    >
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M20.52 3.48A11.84 11.84 0 0 0 12.06 0C5.55 0 .25 5.3.25 11.81c0 2.08.55 4.12 1.6 5.93L0 24l6.45-1.7a11.78 11.78 0 0 0 5.61 1.43h.01c6.51 0 11.81-5.3 11.81-11.81 0-3.15-1.23-6.11-3.36-8.44zM12.07 21.7h-.01a9.8 9.8 0 0 1-4.99-1.37l-.36-.22-3.83 1 1.02-3.73-.24-.38a9.73 9.73 0 0 1-1.5-5.18c0-5.41 4.4-9.81 9.81-9.81 2.62 0 5.08 1.02 6.93 2.87a9.74 9.74 0 0 1 2.88 6.94c0 5.41-4.4 9.81-9.81 9.81z"></path>
      </svg>
    </a>
  </body>
</html>

<style is:global>
  body {
    font-family:
      "Rubik Variable",
      Menlo,
      Monaco,
      Lucida Console,
      Liberation Mono,
      DejaVu Sans Mono,
      Bitstream Vera Sans Mono,
      Courier New,
      monospace;
  }

  .animated-photo {
    animation: kenburns 18s ease-in-out infinite alternate;
    will-change: transform;
  }

  .animated-photo-slow {
    animation: kenburns 24s ease-in-out infinite alternate;
    will-change: transform;
  }

  @keyframes kenburns {
    0% {
      transform: scale(1) translate3d(0, 0, 0);
    }
    100% {
      transform: scale(1.08) translate3d(-1.4%, -1.2%, 0);
    }
  }
