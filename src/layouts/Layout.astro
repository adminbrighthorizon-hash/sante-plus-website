---
import Background from "@/components/Background.astro";
import type { Meta } from "@/config/landing.interface";
import "@fontsource-variable/rubik";

interface Props {
  meta: Meta;
}

const { meta } = Astro.props;

const ldJson = JSON.stringify(meta.ldJson);
const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html
  class="scrollbar-thin scrollbar-thumb-black scrollbar-track-transparent scroll-smooth"
  lang={meta.lang ?? "en"}
>
  <head>
    <meta charset={meta.charset ?? "UTF-8"} />
    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href={`${baseUrl}favicon.svg`} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={`${baseUrl}images/logo.jpeg`} />
    <link rel="canonical" href={import.meta.env.SITE} />
    <script is:inline type="application/ld+json" set:html={ldJson} />
  </head>
  <body class="bg-white">
    <Background />
    <slot />
    <a
      href="https://wa.me/243997007071"
      target="_blank"
      rel="noopener noreferrer"
      class="whatsapp-float"
      aria-label="Chat on WhatsApp"
      title="Chat on WhatsApp"
    >
      <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <path
          d="M16.03 3.2C9 3.2 3.3 8.83 3.3 15.78c0 2.26.6 4.46 1.73 6.4L3.2 28.8l6.77-1.78a12.9 12.9 0 0 0 6.04 1.52h.02c7.03 0 12.73-5.64 12.73-12.6 0-3.36-1.32-6.52-3.6-8.95A12.8 12.8 0 0 0 16.03 3.2Z"
          fill="white"
        />
        <path
          d="M16.01 5.37c-5.82 0-10.55 4.68-10.55 10.44 0 2.03.6 4.02 1.72 5.72l.27.4-1.1 4.01 4.13-1.08.39.23a10.67 10.67 0 0 0 5.13 1.4h.01c5.82 0 10.55-4.68 10.55-10.44 0-2.78-1.09-5.4-3.04-7.36a10.6 10.6 0 0 0-7.5-3.32Z"
          fill="#25D366"
        />
        <path
          d="m21.98 18.69-.08-.12c-.28-.4-.98-.64-1.53-.37l-.93.47c-.25.12-.54.09-.75-.08l-.36-.28a8.16 8.16 0 0 1-1.97-2.17l-.07-.12c-.14-.24-.15-.54-.01-.78l.47-.88c.28-.52.04-1.18-.39-1.45l-.13-.08-.85-.5a1.19 1.19 0 0 0-1.64.45l-.45.76c-.94 1.6-.36 3.64.9 5.12l.33.39a11.95 11.95 0 0 0 3.42 2.69c1.57.8 3.58 1.08 5.21.12l.78-.46c.57-.34.74-1.07.4-1.62l-.52-.84Z"
          fill="white"
        />
      </svg>
      <span>WhatsApp</span>
    </a>
  </body>
</html>

<style is:global>
  body {
    font-family:
      "Rubik Variable",
      Menlo,
      Monaco,
      Lucida Console,
      Liberation Mono,
      DejaVu Sans Mono,
      Bitstream Vera Sans Mono,
      Courier New,
      monospace;
  }

  .animated-photo {
    animation: kenburns 18s ease-in-out infinite alternate;
    will-change: transform;
  }

  .animated-photo-slow {
    animation: kenburns 24s ease-in-out infinite alternate;
    will-change: transform;
  }

  .hero-bg-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero-bg-layer {
    position: absolute;
    inset: -8%;
    background-size: cover;
    background-position: center;
    will-change: transform, filter;
  }

  .hero-bg-layer-main {
    animation: hero-pan-main 15s ease-in-out infinite alternate;
  }

  .hero-bg-layer-accent {
    mix-blend-mode: multiply;
    opacity: 0.3;
    filter: saturate(1.2) contrast(1.06);
    animation: hero-pan-accent 18s ease-in-out infinite alternate;
  }

  .hero-glow-orb {
    position: absolute;
    border-radius: 9999px;
    filter: blur(20px);
    opacity: 0.35;
    animation: hero-orb-float 10s ease-in-out infinite alternate;
  }

  .hero-glow-orb.one {
    width: 16rem;
    height: 16rem;
    top: 10%;
    left: 6%;
    background: rgba(244, 114, 182, 0.45);
  }

  .hero-glow-orb.two {
    width: 18rem;
    height: 18rem;
    right: 8%;
    bottom: 12%;
    background: rgba(16, 185, 129, 0.45);
    animation-delay: -3s;
  }

  @keyframes kenburns {
    0% {
      transform: scale(1) translate3d(0, 0, 0);
    }
    100% {
      transform: scale(1.08) translate3d(-1.4%, -1.2%, 0);
    }
  }

  .whatsapp-float {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 60;
    padding: 0.5rem 0.85rem 0.5rem 0.45rem;
    border-radius: 9999px;
    background: linear-gradient(135deg, #25d366, #128c7e);
    color: #fff;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    justify-content: center;
    box-shadow: 0 10px 24px rgba(18, 140, 126, 0.45);
    animation: pulse-whatsapp 2.2s ease-in-out infinite;
    transition: transform 0.2s ease;
  }

  .whatsapp-float:hover {
    transform: translateY(-2px) scale(1.05);
  }

  .whatsapp-float svg {
    width: 1.9rem;
    height: 1.9rem;
    flex: 0 0 auto;
  }

  .whatsapp-float span {
    font-size: 0.88rem;
    font-weight: 700;
    line-height: 1;
  }

  @media (max-width: 640px) {
    .whatsapp-float {
      right: 0.75rem;
      bottom: 0.75rem;
      padding: 0.45rem;
    }

    .whatsapp-float span {
      display: none;
    }
  }

  @keyframes pulse-whatsapp {
    0%,
    100% {
      box-shadow: 0 10px 24px rgba(18, 140, 126, 0.45);
    }
    50% {
      box-shadow: 0 12px 32px rgba(37, 211, 102, 0.65);
    }
  }

  @keyframes hero-pan-main {
    0% {
      transform: scale(1.05) translate3d(0, 0, 0);
    }
    100% {
      transform: scale(1.16) translate3d(-3.5%, -2.5%, 0);
    }
  }

  @keyframes hero-pan-accent {
    0% {
      transform: scale(1.04) translate3d(0, 0, 0);
    }
    100% {
      transform: scale(1.17) translate3d(3.5%, 2.5%, 0);
    }
  }

  @keyframes hero-orb-float {
    0% {
      transform: translate3d(0, 0, 0) scale(1);
    }
    100% {
      transform: translate3d(24px, -18px, 0) scale(1.12);
    }
  }
</style>
