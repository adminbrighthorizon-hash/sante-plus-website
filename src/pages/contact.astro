---
import Layout from "@/layouts/Layout.astro";
import Footer from "@/sections/Footer.astro";
import Header from "@/sections/Header.astro";
import { getLandingData } from "@/services/data.service";

const data = await getLandingData();
---

<Layout meta={data.meta}>
  <Header data={data.headerData} lang="en" />
  <main class="flex flex-col items-center pt-36 pb-16">
    <section class="w-11/12 md:w-3/4 rounded-3xl border-2 border-secondary bg-gradient-to-br from-white via-secondary/10 to-primary/10 p-8 md:p-12 shadow-xl shadow-secondary/20">
      <p class="w-fit mx-auto mb-4 rounded-full bg-secondary/15 border border-secondary px-4 py-2 text-sm font-semibold">
        We are here for you
      </p>
      <h1 class="text-4xl md:text-6xl font-semibold text-center">
        Let's Talk About Your Self-Care Journey
      </h1>
      <p class="mt-6 text-center md:text-xl opacity-90">
        Our team is here to answer your questions and guide you through better
        natural wellness routines.
      </p>
      <p class="mt-3 text-center text-base md:text-lg font-medium text-black/80">
        Active support in Lubumbashi, Kolwezi, Kinshasa, and Johannesburg.
      </p>
      <div class="mt-8 flex flex-col md:flex-row gap-4 justify-center">
        <a
          href="https://wa.me/243997007071"
          target="_blank"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg text-center font-semibold bg-secondary text-white shadow-lg shadow-secondary/40 hover:opacity-90 transition"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.52 3.48A11.84 11.84 0 0 0 12.06 0C5.55 0 .25 5.3.25 11.81c0 2.08.55 4.12 1.6 5.93L0 24l6.45-1.7a11.78 11.78 0 0 0 5.61 1.43h.01c6.51 0 11.81-5.3 11.81-11.81 0-3.15-1.23-6.11-3.36-8.44zM12.07 21.7h-.01a9.8 9.8 0 0 1-4.99-1.37l-.36-.22-3.83 1 1.02-3.73-.24-.38a9.73 9.73 0 0 1-1.5-5.18c0-5.41 4.4-9.81 9.81-9.81 2.62 0 5.08 1.02 6.93 2.87a9.74 9.74 0 0 1 2.88 6.94c0 5.41-4.4 9.81-9.81 9.81z"></path></svg>
          Chat on WhatsApp
        </a>
        <a
          href="https://www.instagram.com/santeplus"
          target="_blank"
          class="px-6 py-3 rounded-lg text-center font-semibold border border-secondary bg-white"
        >
          Follow on Instagram
        </a>
      </div>
    </section>

    <section class="w-11/12 md:w-3/4 mt-12 grid md:grid-cols-2 gap-8">
      <article class="rounded-2xl border border-primary bg-white p-6 shadow-md">
        <img
          src="https://images.unsplash.com/photo-1490818387583-1baba5e638af?auto=format&fit=crop&w=1200&q=80"
          alt="Natural herbal tea cup"
          class="rounded-xl h-64 w-full object-cover animated-photo"
        />
        <h2 class="text-2xl font-semibold mt-5">Response Hours</h2>
        <p class="mt-3 opacity-90">
          Monday to Saturday, 8:00 AM - 6:00 PM (UTC+2). We always aim to reply quickly.
        </p>
      </article>

      <article class="rounded-2xl border border-secondary bg-white p-6 shadow-md">
        <img
          src="https://images.unsplash.com/photo-1464226184884-fa280b87c399?auto=format&fit=crop&w=1200&q=80"
          alt="Natural products and green leaves"
          class="rounded-xl h-64 w-full object-cover animated-photo"
        />
        <h2 class="text-2xl font-semibold mt-5">Personalized Guidance</h2>
        <p class="mt-3 opacity-90">
          Get practical recommendations tailored to your wellness goals and daily routine.
        </p>
      </article>
    </section>

    <section class="w-11/12 md:w-3/4 mt-10 rounded-2xl border border-secondary bg-white p-8 shadow-md">
      <h2 class="text-3xl font-semibold">Regional Presence</h2>
      <div class="mt-5 grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="rounded-xl border border-primary bg-primary/20 p-4">
          <p class="font-semibold">Lubumbashi</p>
          <p class="text-sm mt-1 opacity-80">Main wellness coordination</p>
        </div>
        <div class="rounded-xl border border-primary bg-primary/20 p-4">
          <p class="font-semibold">Kolwezi</p>
          <p class="text-sm mt-1 opacity-80">Community health support</p>
        </div>
        <div class="rounded-xl border border-primary bg-primary/20 p-4">
          <p class="font-semibold">Kinshasa</p>
          <p class="text-sm mt-1 opacity-80">Urban wellness outreach</p>
        </div>
        <div class="rounded-xl border border-primary bg-primary/20 p-4">
          <p class="font-semibold">Johannesburg</p>
          <p class="text-sm mt-1 opacity-80">Cross-border client support</p>
        </div>
      </div>
    </section>
  </main>
  <Footer data={data.footerData} lang="en" />
</Layout>
