---
import Layout from "@/layouts/Layout.astro";
import Footer from "@/sections/Footer.astro";
import Header from "@/sections/Header.astro";
import { getLandingData } from "@/services/data.service";

const data = await getLandingData();
const baseUrl = import.meta.env.BASE_URL;
---

<Layout meta={data.meta}>
  <Header data={data.headerData} lang="en" />
  <main class="flex flex-col items-center">
    <section class="relative w-full min-h-screen flex items-center justify-center overflow-hidden pt-28">
      <div class="hero-bg-wrap" aria-hidden="true">
        <div
          class="hero-bg-layer hero-bg-layer-main"
          style={`background-image: url('${baseUrl}images/soursop-tree.jpg');`}
        ></div>
        <div
          class="hero-bg-layer hero-bg-layer-accent"
          style={`background-image: url('${baseUrl}images/shopping.webp');`}
        ></div>
        <div class="hero-glow-orb one"></div>
        <div class="hero-glow-orb two"></div>
        <div class="absolute inset-0 bg-gradient-to-br from-white/90 via-primary/70 to-secondary/45"></div>
      </div>
      <div class="relative z-10 w-11/12 md:w-3/4 rounded-3xl border-2 border-primary/80 bg-white/90 p-8 md:p-12 shadow-2xl shadow-secondary/30">
        <p class="w-fit mx-auto mb-5 rounded-full border border-secondary bg-primary/70 px-4 py-2 text-sm font-semibold">
          Elegant Wellness for Modern Women
        </p>
        <h1 class="text-4xl md:text-6xl text-center font-semibold leading-tight">
          Feel Better Naturally with <span class="text-secondary drop-shadow-sm">Santé Plus</span>
        </h1>
        <p class="mt-6 text-center md:text-xl opacity-90">
          A modern wellness platform rooted in DR Congo and South Africa, focused
          on practical soursop-leaf routines for vitality and mindful living.
        </p>
        <p class="mt-3 text-center text-base md:text-lg font-medium text-black/80">
          Lubumbashi • Kolwezi • Kinshasa • Johannesburg
        </p>
        <div class="mt-8 flex flex-col md:flex-row gap-4 justify-center">
          <a href="https://wa.me/243997007071" target="_blank" class="inline-flex items-center justify-center gap-2 px-7 py-3 rounded-full text-center font-semibold bg-green-600 text-white shadow-lg shadow-green-700/40 hover:bg-green-700 transition">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.52 3.48A11.84 11.84 0 0 0 12.06 0C5.55 0 .25 5.3.25 11.81c0 2.08.55 4.12 1.6 5.93L0 24l6.45-1.7a11.78 11.78 0 0 0 5.61 1.43h.01c6.51 0 11.81-5.3 11.81-11.81 0-3.15-1.23-6.11-3.36-8.44zM12.07 21.7h-.01a9.8 9.8 0 0 1-4.99-1.37l-.36-.22-3.83 1 1.02-3.73-.24-.38a9.73 9.73 0 0 1-1.5-5.18c0-5.41 4.4-9.81 9.81-9.81 2.62 0 5.08 1.02 6.93 2.87a9.74 9.74 0 0 1 2.88 6.94c0 5.41-4.4 9.81-9.81 9.81z"></path></svg>
            Chat on WhatsApp
          </a>
          <a href={`${baseUrl}bienfaits`} class="px-7 py-3 rounded-full text-center font-semibold border-2 border-secondary bg-white hover:bg-primary/40 transition">
            Explore Benefits
          </a>
        </div>
        <div class="mt-4 flex flex-col sm:flex-row gap-3 justify-center">
          <a href="https://www.instagram.com/santeplus" target="_blank" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-full text-center font-semibold text-white bg-gradient-to-r from-fuchsia-600 via-pink-600 to-orange-500 shadow-lg shadow-pink-600/35 hover:brightness-110 transition">
            <span class="text-base leading-none">◎</span>
            Instagram
          </a>
          <a href="https://www.tiktok.com/@santeplus" target="_blank" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-full text-center font-semibold text-white bg-slate-900 shadow-lg shadow-slate-900/40 hover:bg-black transition">
            <span class="text-base leading-none">♪</span>
            TikTok
          </a>
        </div>
      </div>
    </section>

    <section class="w-11/12 md:w-3/4 pb-16">
      <div class="rounded-3xl border border-secondary/70 bg-white/90 p-8 md:p-10 shadow-xl shadow-secondary/15">
        <h2 class="text-3xl md:text-4xl text-center font-semibold">Wellness Concept Inspired by Community Care</h2>
        <p class="mt-4 text-center md:text-lg opacity-90">
          A practical routine inspired by your concept notes: simple habits, consistency, and responsible natural support for women.
        </p>
        <div class="mt-8 grid md:grid-cols-2 gap-6">
          <article class="rounded-2xl border border-primary/50 bg-primary/10 p-6">
            <h3 class="text-2xl font-semibold">Daily Routine Essentials</h3>
            <ul class="mt-4 space-y-2 opacity-90">
              <li>- Sleep enough and stay hydrated.</li>
              <li>- Include vitamin-rich foods (C and D) and balanced nutrition.</li>
              <li>- Use soursop-leaf infusion in moderation.</li>
              <li>- Keep stress low, move your body, and protect your peace.</li>
            </ul>
            <p class="mt-4 text-sm font-semibold text-red-700">
              Important: Avoid soursop-leaf use during pregnancy and breastfeeding.
            </p>
          </article>
          <article class="rounded-2xl border border-secondary/60 bg-secondary/10 p-6">
            <h3 class="text-2xl font-semibold">Featured Oils (Cold-Pressed)</h3>
            <div class="mt-4 space-y-4">
              <div class="rounded-xl border border-secondary/40 bg-white p-4">
                <p class="font-semibold">Black Seed Oil (Nigella)</p>
                <p class="mt-1 text-sm opacity-90">
                  Traditionally used for soothing support and comfort in everyday wellness routines.
                </p>
              </div>
              <div class="rounded-xl border border-secondary/40 bg-white p-4">
                <p class="font-semibold">Castor Oil</p>
                <p class="mt-1 text-sm opacity-90">
                  Commonly used in gentle massage rituals to support comfort and circulation.
                </p>
              </div>
            </div>
            <p class="mt-4 text-sm opacity-80">
              These routines support wellbeing but do not replace medical advice or treatment.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="w-11/12 md:w-3/4 py-16">
      <h2 class="text-3xl md:text-5xl text-center font-semibold">Why Santé Plus Stands Out</h2>
      <div class="mt-10 grid md:grid-cols-3 gap-6">
        <article class="rounded-2xl border border-primary bg-white p-6 shadow-md hover:shadow-xl hover:shadow-secondary/20 transition">
          <img src={`${baseUrl}images/soursop-tea.jpg`} alt="Herbal tea cup" class="rounded-xl h-48 w-full object-cover animated-photo" />
          <h3 class="text-2xl font-semibold mt-4">Simple Guidance</h3>
          <p class="mt-2 opacity-90">Straightforward tips that make natural wellness easy to apply daily.</p>
        </article>
        <article class="rounded-2xl border border-secondary bg-white p-6 shadow-md hover:shadow-xl hover:shadow-secondary/20 transition">
          <img src={`${baseUrl}images/shopping.webp`} alt="Natural wellness products display" class="rounded-xl h-48 w-full object-cover animated-photo" />
          <h3 class="text-2xl font-semibold mt-4">Natural Focus</h3>
          <p class="mt-2 opacity-90">Soursop leaf routines centered on consistency, moderation, and wellbeing.</p>
        </article>
        <article class="rounded-2xl border border-primary bg-white p-6 shadow-md hover:shadow-xl hover:shadow-secondary/20 transition">
          <img src={`${baseUrl}images/product.webp`} alt="Natural products and plants" class="rounded-xl h-48 w-full object-cover animated-photo" />
          <h3 class="text-2xl font-semibold mt-4">Human Support</h3>
          <p class="mt-2 opacity-90">Direct WhatsApp support to answer your questions and build better habits.</p>
        </article>
      </div>
    </section>

    <section class="w-11/12 md:w-3/4 pb-16">
      <div class="rounded-3xl border border-secondary/70 bg-white/85 backdrop-blur-sm p-8 md:p-10 shadow-2xl shadow-secondary/20">
        <h3 class="text-3xl md:text-4xl font-semibold text-center">Your Daily Glow Ritual</h3>
        <p class="mt-4 text-center md:text-lg opacity-90">
          A feminine, easy rhythm that helps you stay consistent: hydrate, infuse, nourish, and reset.
        </p>
        <div class="mt-8 grid md:grid-cols-4 gap-4">
          <div class="rounded-2xl border border-primary/60 bg-primary/10 p-5">
            <p class="text-sm uppercase tracking-wide font-semibold text-secondary">Step 01</p>
            <h4 class="mt-2 text-xl font-semibold">Morning Boost</h4>
            <p class="mt-2 opacity-90">Start with warm infusion and a glass of water to wake your body gently.</p>
          </div>
          <div class="rounded-2xl border border-primary/60 bg-primary/10 p-5">
            <p class="text-sm uppercase tracking-wide font-semibold text-secondary">Step 02</p>
            <h4 class="mt-2 text-xl font-semibold">Midday Balance</h4>
            <p class="mt-2 opacity-90">Pair your routine with fruit, greens, and 10 minutes of mindful breathing.</p>
          </div>
          <div class="rounded-2xl border border-primary/60 bg-primary/10 p-5">
            <p class="text-sm uppercase tracking-wide font-semibold text-secondary">Step 03</p>
            <h4 class="mt-2 text-xl font-semibold">Evening Reset</h4>
            <p class="mt-2 opacity-90">Take a lighter cup, journal your mood, and keep your sleep routine steady.</p>
          </div>
          <div class="rounded-2xl border border-primary/60 bg-primary/10 p-5">
            <p class="text-sm uppercase tracking-wide font-semibold text-secondary">Step 04</p>
            <h4 class="mt-2 text-xl font-semibold">Weekly Check-In</h4>
            <p class="mt-2 opacity-90">Review what worked and get personalized guidance through WhatsApp support.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="w-11/12 md:w-3/4 pb-16">
      <div class="rounded-3xl border border-primary bg-white p-8 md:p-10 shadow-lg">
        <h3 class="text-3xl md:text-4xl font-semibold text-center">Built for Congo, Trusted in Johannesburg</h3>
        <p class="mt-4 text-center md:text-lg opacity-90">
          Our wellness guidance speaks to local realities: climate, daily routines,
          and community habits across Lubumbashi, Kolwezi, Kinshasa, and Johannesburg.
        </p>
        <div class="mt-8 grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <div class="rounded-xl bg-primary/20 border border-primary p-4 text-center font-semibold">Lubumbashi</div>
          <div class="rounded-xl bg-primary/20 border border-primary p-4 text-center font-semibold">Kolwezi</div>
          <div class="rounded-xl bg-primary/20 border border-primary p-4 text-center font-semibold">Kinshasa</div>
          <div class="rounded-xl bg-primary/20 border border-primary p-4 text-center font-semibold">Johannesburg</div>
        </div>
      </div>
    </section>

    <section class="w-11/12 md:w-3/4 pb-20">
      <div class="rounded-3xl border border-secondary bg-gradient-to-r from-primary/60 via-white to-secondary/40 p-8 md:p-10">
        <h3 class="text-3xl md:text-4xl font-semibold text-center">Start Your Wellness Journey Today</h3>
        <p class="mt-4 text-center md:text-lg opacity-90">
          Learn how to prepare your infusion, build a practical routine, and stay consistent with expert-backed guidance.
        </p>
        <div class="mt-7 flex justify-center">
          <a href={`${baseUrl}contact`} class="px-8 py-3 rounded-full text-center font-semibold bg-secondary text-white shadow-lg shadow-secondary/40 hover:opacity-90 transition">
            Get Personalized Support
          </a>
        </div>
      </div>
    </section>

    <section class="w-11/12 md:w-3/4 pb-24">
      <h3 class="text-3xl md:text-4xl font-semibold text-center">What Women Say About Santé Plus</h3>
      <div class="mt-8 grid md:grid-cols-3 gap-5">
        <article class="rounded-2xl border border-secondary/60 bg-white p-6 shadow-lg">
          <p class="text-lg leading-relaxed">"I feel more consistent now. The routine is simple, classy, and fits my busy week."</p>
          <p class="mt-4 text-sm font-semibold uppercase tracking-wide text-secondary">Aline • Lubumbashi</p>
        </article>
        <article class="rounded-2xl border border-secondary/60 bg-white p-6 shadow-lg">
          <p class="text-lg leading-relaxed">"The guidance feels personal. I love the feminine tone and practical daily steps."</p>
          <p class="mt-4 text-sm font-semibold uppercase tracking-wide text-secondary">Ruth • Kinshasa</p>
        </article>
        <article class="rounded-2xl border border-secondary/60 bg-white p-6 shadow-lg">
          <p class="text-lg leading-relaxed">"Beautiful visuals, clear support, and real results from consistent healthy habits."</p>
          <p class="mt-4 text-sm font-semibold uppercase tracking-wide text-secondary">Lebo • Johannesburg</p>
        </article>
      </div>
    </section>
  </main>
  <Footer data={data.footerData} lang="en" />
</Layout>
