---
import Layout from "@/layouts/Layout.astro";
import Footer from "@/sections/Footer.astro";
import Header from "@/sections/Header.astro";
import { getLandingData } from "@/services/data.service";

const data = await getLandingData();
---

<Layout meta={data.meta}>
  <Header data={data.headerData} />
  <main class="flex flex-col items-center pt-36 pb-16">
    <section class="w-11/12 md:w-3/4 rounded-3xl border-2 border-secondary/60 bg-gradient-to-br from-white via-primary/10 to-secondary/10 backdrop-blur-sm p-8 md:p-12 shadow-xl shadow-secondary/20">
      <p class="w-fit mx-auto mb-4 rounded-full bg-secondary/15 border border-secondary px-4 py-2 text-sm font-semibold">
        Wellness Spotlight
      </p>
      <h1 class="text-4xl md:text-6xl font-semibold text-center">
        Benefits of <span class="text-secondary">Soursop Leaves (feuilles de corossol)</span>
      </h1>
      <p class="mt-6 text-center md:text-xl opacity-90">
        Discover practical, wellness-focused ways to include soursop leaves in
        your routine with clarity and confidence.
      </p>
      <p class="mt-3 text-center text-base md:text-lg font-medium text-black/80">
        Wellness insights for Lubumbashi, Kolwezi, Kinshasa, and Johannesburg.
      </p>
    </section>

    <section class="w-11/12 md:w-3/4 mt-12 grid md:grid-cols-2 gap-8">
      <article class="rounded-2xl border border-primary/60 bg-white p-6 shadow-lg hover:shadow-2xl hover:shadow-secondary/20 transition">
        <img
          src="/images/soursop-tea.jpg"
          alt="Fresh green medicinal plants"
          class="rounded-xl h-64 w-full object-cover"
        />
        <h2 class="text-2xl font-semibold mt-5">Daily Immune Support</h2>
        <p class="mt-3 opacity-90">
          Traditionally used to support natural body defenses, helping you feel
          more balanced and energized.
        </p>
      </article>

      <article class="rounded-2xl border border-secondary/70 bg-white p-6 shadow-lg hover:shadow-2xl hover:shadow-secondary/20 transition">
        <img
          src="/images/soursop-tree.jpg"
          alt="Soursop leaves close-up"
          class="rounded-xl h-64 w-full object-cover"
        />
        <h2 class="text-2xl font-semibold mt-5">Responsible Wellness Routine</h2>
        <p class="mt-3 opacity-90">
          Santé Plus promotes moderate use together with hydration, balanced
          nutrition, and professional medical guidance.
        </p>
      </article>
    </section>

    <section class="w-11/12 md:w-3/4 mt-10 rounded-2xl border border-secondary bg-primary/35 p-8">
      <h3 class="text-3xl font-semibold">How to Prepare Your Infusion</h3>
      <ul class="mt-5 flex flex-col gap-3 text-lg">
        <li>1. Boil clean water.</li>
        <li>2. Add a few dried soursop leaves.</li>
        <li>3. Let it steep for 10 to 15 minutes.</li>
        <li>4. Filter and drink in moderation.</li>
      </ul>
    </section>

    <section class="w-11/12 md:w-3/4 mt-10 rounded-2xl border border-primary bg-white p-8 shadow-md">
      <h3 class="text-3xl font-semibold">Local Lifestyle Fit</h3>
      <p class="mt-4 md:text-lg opacity-90">
        Whether you are in Lubumbashi, Kolwezi, Kinshasa, or Johannesburg, the
        same principle applies: keep it simple, stay consistent, and combine
        natural support with healthy nutrition and professional advice.
      </p>
    </section>
  </main>
  <Footer data={data.footerData} />
</Layout>
