---
import Layout from "@/layouts/Layout.astro";
import Footer from "@/sections/Footer.astro";
import Header from "@/sections/Header.astro";
import { getLandingData } from "@/services/data.service";

const data = await getLandingData();
---

<Layout meta={{ ...data.meta, lang: "fr", title: "Bienfaits des feuilles de corossol | Sante Plus", description: "Decouvrez des usages bien-etre responsables des feuilles de corossol avec Sante Plus." }}>
  <Header data={data.headerData} lang="fr" />
  <main class="flex flex-col items-center pt-36 pb-16">
    <section class="w-11/12 md:w-3/4 rounded-3xl border-2 border-secondary/60 bg-gradient-to-br from-white via-primary/10 to-secondary/10 backdrop-blur-sm p-8 md:p-12 shadow-xl shadow-secondary/20">
      <p class="w-fit mx-auto mb-4 rounded-full bg-secondary/15 border border-secondary px-4 py-2 text-sm font-semibold">Focus bien-etre</p>
      <h1 class="text-4xl md:text-6xl font-semibold text-center">Bienfaits des <span class="text-secondary">feuilles de corossol</span></h1>
      <p class="mt-6 text-center md:text-xl opacity-90">Des conseils pratiques pour integrer les feuilles de corossol a votre routine avec clarte et serenite.</p>
    </section>

    <section class="w-11/12 md:w-3/4 mt-12 grid md:grid-cols-2 gap-8">
      <article class="rounded-2xl border border-primary/60 bg-white p-6 shadow-lg hover:shadow-2xl hover:shadow-secondary/20 transition">
        <img src="https://images.unsplash.com/photo-1501004318641-b39e6451bec6?auto=format&fit=crop&w=1200&q=80" alt="Plantes medicinales vertes" class="rounded-xl h-64 w-full object-cover animated-photo" />
        <h2 class="text-2xl font-semibold mt-5">Soutien des defenses naturelles</h2>
        <p class="mt-3 opacity-90">Traditionnellement utilisees pour accompagner l'equilibre et la vitalite du corps.</p>
      </article>
      <article class="rounded-2xl border border-secondary/70 bg-white p-6 shadow-lg hover:shadow-2xl hover:shadow-secondary/20 transition">
        <img src="https://images.unsplash.com/photo-1471193945509-9ad0617afabf?auto=format&fit=crop&w=1200&q=80" alt="Feuilles de corossol" class="rounded-xl h-64 w-full object-cover animated-photo" />
        <h2 class="text-2xl font-semibold mt-5">Routine responsable</h2>
        <p class="mt-3 opacity-90">Toujours associer cette habitude a l'hydratation, une bonne alimentation et un avis medical.</p>
      </article>
    </section>

    <section class="w-11/12 md:w-3/4 mt-10 rounded-2xl border border-secondary bg-primary/25 p-8">
      <h3 class="text-3xl font-semibold">Preparation signature Sante Plus</h3>
      <ul class="mt-5 flex flex-col gap-3 text-lg">
        <li>1. Faire bouillir de l'eau propre.</li>
        <li>2. Ajouter quelques feuilles sechees de corossol.</li>
        <li>3. Laisser infuser 10 a 15 minutes.</li>
        <li>4. Filtrer puis boire avec moderation.</li>
      </ul>
    </section>

    <section class="w-11/12 md:w-3/4 mt-10 grid md:grid-cols-3 gap-5">
      <article class="rounded-2xl border border-primary bg-white p-6 shadow-md">
        <h4 class="text-xl font-semibold">Energie feminine</h4>
        <p class="mt-3 opacity-90">Des habitudes douces pour soutenir la vitalite sans alourdir votre rythme.</p>
      </article>
      <article class="rounded-2xl border border-primary bg-white p-6 shadow-md">
        <h4 class="text-xl font-semibold">Peau & bien-etre global</h4>
        <p class="mt-3 opacity-90">Hydratation, infusion et alimentation coloree pour un eclat plus harmonieux.</p>
      </article>
      <article class="rounded-2xl border border-primary bg-white p-6 shadow-md">
        <h4 class="text-xl font-semibold">Routine durable</h4>
        <p class="mt-3 opacity-90">Simplicite, regularite et suivi: les trois cles pour des resultats visibles.</p>
      </article>
    </section>
  </main>
  <Footer data={data.footerData} lang="fr" />
</Layout>
