---
import Layout from "@/layouts/Layout.astro";
import Footer from "@/sections/Footer.astro";
import Header from "@/sections/Header.astro";
import { getLandingData } from "@/services/data.service";

const data = await getLandingData();
const baseUrl = import.meta.env.BASE_URL;
---

<Layout meta={{ ...data.meta, lang: "fr", title: "Sante Plus | Bien-etre naturel en RDC et Afrique du Sud", description: "Sante Plus propose un accompagnement bien-etre naturel a Lubumbashi, Kolwezi, Kinshasa et Johannesburg." }}>
  <Header data={data.headerData} lang="fr" />
  <main class="flex flex-col items-center">
    <section class="relative w-full min-h-screen flex items-center justify-center overflow-hidden pt-28">
      <div class="hero-bg-wrap" aria-hidden="true">
        <div
          class="hero-bg-layer hero-bg-layer-main"
          style={`background-image: url('${baseUrl}images/soursop-tree.jpg');`}
        ></div>
        <div
          class="hero-bg-layer hero-bg-layer-accent"
          style={`background-image: url('${baseUrl}images/shopping.webp');`}
        ></div>
        <div class="hero-glow-orb one"></div>
        <div class="hero-glow-orb two"></div>
        <div class="absolute inset-0 bg-gradient-to-br from-white/90 via-primary/70 to-secondary/45"></div>
      </div>
      <div class="relative z-10 w-11/12 md:w-3/4 rounded-3xl border-2 border-primary/80 bg-white/90 p-8 md:p-12 shadow-2xl shadow-secondary/30">
        <p class="w-fit mx-auto mb-5 rounded-full border border-secondary bg-primary/70 px-4 py-2 text-sm font-semibold">
          Bien-etre elegant pour la femme moderne
        </p>
        <h1 class="text-4xl md:text-6xl text-center font-semibold leading-tight">
          Retrouvez votre bien-etre naturellement avec <span class="text-secondary drop-shadow-sm">Sante Plus</span>
        </h1>
        <p class="mt-6 text-center md:text-xl opacity-90">
          Une plateforme moderne de bien-etre ancree en RDC et en Afrique du Sud, centree sur des routines pratiques autour des feuilles de corossol pour la vitalite et une vie sereine.
        </p>
        <p class="mt-3 text-center text-base md:text-lg font-medium text-black/80">
          Lubumbashi • Kolwezi • Kinshasa • Johannesburg
        </p>
        <div class="mt-8 flex flex-col md:flex-row gap-4 justify-center">
          <a href="https://wa.me/243997007071" target="_blank" class="inline-flex w-full sm:w-auto items-center justify-center gap-2 px-7 py-3 rounded-full text-center font-bold bg-green-600 text-white border-2 border-green-800 shadow-xl shadow-green-900/40 ring-2 ring-white/80 hover:bg-green-700 transition">
            <svg class="h-5 w-5 shrink-0" viewBox="0 0 32 32" fill="none" aria-hidden="true">
              <path d="M16.03 3.2C9 3.2 3.3 8.83 3.3 15.78c0 2.26.6 4.46 1.73 6.4L3.2 28.8l6.77-1.78a12.9 12.9 0 0 0 6.04 1.52h.02c7.03 0 12.73-5.64 12.73-12.6 0-3.36-1.32-6.52-3.6-8.95A12.8 12.8 0 0 0 16.03 3.2Z" fill="white"></path>
              <path d="M16.01 5.37c-5.82 0-10.55 4.68-10.55 10.44 0 2.03.6 4.02 1.72 5.72l.27.4-1.1 4.01 4.13-1.08.39.23a10.67 10.67 0 0 0 5.13 1.4h.01c5.82 0 10.55-4.68 10.55-10.44 0-2.78-1.09-5.4-3.04-7.36a10.6 10.6 0 0 0-7.5-3.32Z" fill="#25D366"></path>
              <path d="m21.98 18.69-.08-.12c-.28-.4-.98-.64-1.53-.37l-.93.47c-.25.12-.54.09-.75-.08l-.36-.28a8.16 8.16 0 0 1-1.97-2.17l-.07-.12c-.14-.24-.15-.54-.01-.78l.47-.88c.28-.52.04-1.18-.39-1.45l-.13-.08-.85-.5a1.19 1.19 0 0 0-1.64.45l-.45.76c-.94 1.6-.36 3.64.9 5.12l.33.39a11.95 11.95 0 0 0 3.42 2.69c1.57.8 3.58 1.08 5.21.12l.78-.46c.57-.34.74-1.07.4-1.62l-.52-.84Z" fill="white"></path>
            </svg>
            Contacter sur WhatsApp
          </a>
          <a href={`${baseUrl}fr/bienfaits`} class="w-full sm:w-auto px-7 py-3 rounded-full text-center font-semibold border-2 border-secondary bg-white shadow-lg shadow-secondary/20 hover:bg-primary/40 transition">
            Voir les bienfaits
          </a>
        </div>
        <div class="mt-4 flex flex-col sm:flex-row gap-3 justify-center">
          <a href="https://www.instagram.com/santeplus" target="_blank" class="inline-flex w-full sm:w-auto items-center justify-center gap-2 px-5 py-3 rounded-full text-center font-bold text-white border-2 border-fuchsia-200 bg-gradient-to-r from-fuchsia-700 via-pink-700 to-orange-600 shadow-xl shadow-pink-700/40 ring-2 ring-white/70 hover:brightness-110 transition">
            <span class="text-base leading-none">◎</span>
            Instagram
          </a>
          <a href="https://www.tiktok.com/@santeplus" target="_blank" class="inline-flex w-full sm:w-auto items-center justify-center gap-2 px-5 py-3 rounded-full text-center font-bold text-white border-2 border-slate-300 bg-slate-900 shadow-xl shadow-black/40 ring-2 ring-white/70 hover:bg-black transition">
            <span class="text-base leading-none">♪</span>
            TikTok
          </a>
        </div>
      </div>
    </section>

    <section class="w-11/12 md:w-3/4 pb-16">
      <div class="rounded-3xl border border-secondary/70 bg-gradient-to-br from-white via-primary/15 to-secondary/20 p-8 md:p-10 shadow-2xl shadow-secondary/25 ring-1 ring-white/60">
        <p class="mx-auto w-fit rounded-full border border-secondary/40 bg-white/85 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.2em] text-secondary">Concept bien-etre premium</p>
        <h2 class="mt-4 text-3xl md:text-4xl text-center font-semibold">Concept bien-etre inspire par la communaute</h2>
        <p class="mt-4 text-center md:text-lg opacity-90 max-w-3xl mx-auto">
          Une routine pratique inspiree de vos notes de concept : habitudes simples, regularite et accompagnement naturel responsable pour les femmes.
        </p>
        <div class="mt-8 grid md:grid-cols-2 gap-6">
          <article class="rounded-2xl border border-primary/60 bg-white p-6 shadow-xl shadow-primary/15 ring-1 ring-primary/20">
            <h3 class="text-2xl font-semibold">Essentiels du quotidien</h3>
            <ul class="mt-5 space-y-3">
              <li class="flex items-start gap-3 rounded-xl bg-primary/5 px-3 py-2"><span class="mt-0.5 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-secondary text-xs font-bold text-white">1</span><span class="opacity-90">Dormir suffisamment et bien s'hydrater.</span></li>
              <li class="flex items-start gap-3 rounded-xl bg-primary/5 px-3 py-2"><span class="mt-0.5 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-secondary text-xs font-bold text-white">2</span><span class="opacity-90">Privilegier une alimentation riche en vitamines (C et D) et equilibree.</span></li>
              <li class="flex items-start gap-3 rounded-xl bg-primary/5 px-3 py-2"><span class="mt-0.5 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-secondary text-xs font-bold text-white">3</span><span class="opacity-90">Utiliser l'infusion de feuilles de corossol avec moderation.</span></li>
              <li class="flex items-start gap-3 rounded-xl bg-primary/5 px-3 py-2"><span class="mt-0.5 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-secondary text-xs font-bold text-white">4</span><span class="opacity-90">Reduire le stress, bouger le corps et proteger son equilibre.</span></li>
            </ul>
          </article>
          <article class="rounded-2xl border border-secondary/60 bg-white p-6 shadow-xl shadow-secondary/20 ring-1 ring-secondary/20">
            <h3 class="text-2xl font-semibold">Huiles mises en avant (pression a froid)</h3>
            <div class="mt-4 space-y-4">
              <div class="rounded-xl border border-secondary/40 bg-white/95 p-4 shadow-xl shadow-secondary/20">
                <img src={`${baseUrl}images/black-seed-oil.jpg`} alt="Huile de nigelle pressee a froid" class="h-52 w-full rounded-xl border border-secondary/30 object-cover shadow-md saturate-125 contrast-110 brightness-105 transition duration-300 hover:scale-[1.02]" />
                <p class="mt-3 text-lg font-bold">Huile de nigelle</p>
                <p class="mt-1 text-sm opacity-90">
                  Utilisee traditionnellement pour un soutien apaisant et le confort au quotidien.
                </p>
              </div>
              <div class="rounded-xl border border-secondary/40 bg-white/95 p-4 shadow-xl shadow-secondary/20">
                <img src={`${baseUrl}images/castor-oil.jpg`} alt="Huile de ricin utilisee en massage bien-etre" class="h-52 w-full rounded-xl border border-secondary/30 object-cover shadow-md saturate-125 contrast-110 brightness-105 transition duration-300 hover:scale-[1.02]" />
                <p class="mt-3 text-lg font-bold">Huile de ricin</p>
                <p class="mt-1 text-sm opacity-90">
                  Souvent utilisee dans des massages doux pour le confort et la circulation.
                </p>
              </div>
            </div>
            <p class="mt-5 rounded-lg border border-secondary/30 bg-secondary/10 px-3 py-2 text-sm font-medium opacity-90">
              Ces routines soutiennent le bien-etre mais ne remplacent pas un avis medical ni un traitement.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="w-11/12 md:w-3/4 py-16">
      <h2 class="text-3xl md:text-5xl text-center font-semibold">Pourquoi Sante Plus se distingue</h2>
      <div class="mt-10 grid md:grid-cols-3 gap-6">
        <article class="rounded-2xl border border-primary bg-white p-6 shadow-md hover:shadow-xl hover:shadow-secondary/20 transition">
          <img src={`${baseUrl}images/soursop-tea.jpg`} alt="Tasse d'infusion" class="rounded-xl h-48 w-full object-cover animated-photo" />
          <h3 class="text-2xl font-semibold mt-4">Guidance simple</h3>
          <p class="mt-2 opacity-90">Des conseils clairs pour appliquer le bien-etre naturel au quotidien sans complication.</p>
        </article>
        <article class="rounded-2xl border border-secondary bg-white p-6 shadow-md hover:shadow-xl hover:shadow-secondary/20 transition">
          <img src={`${baseUrl}images/shopping.webp`} alt="Produits naturels bien-etre" class="rounded-xl h-48 w-full object-cover animated-photo" />
          <h3 class="text-2xl font-semibold mt-4">Focus naturel</h3>
          <p class="mt-2 opacity-90">Des routines autour des feuilles de corossol centrees sur la regularite, la moderation et le bien-etre.</p>
        </article>
        <article class="rounded-2xl border border-primary bg-white p-6 shadow-md hover:shadow-xl hover:shadow-secondary/20 transition">
          <img src={`${baseUrl}images/product.webp`} alt="Produits naturels et plantes" class="rounded-xl h-48 w-full object-cover animated-photo" />
          <h3 class="text-2xl font-semibold mt-4">Accompagnement humain</h3>
          <p class="mt-2 opacity-90">Un soutien direct sur WhatsApp pour repondre a vos questions et ancrer de meilleures habitudes.</p>
        </article>
      </div>
    </section>

    <section class="w-11/12 md:w-3/4 pb-16">
      <div class="rounded-3xl border border-secondary/70 bg-white/85 backdrop-blur-sm p-8 md:p-10 shadow-2xl shadow-secondary/20">
        <h3 class="text-3xl md:text-4xl font-semibold text-center">Votre rituel glow quotidien</h3>
        <p class="mt-4 text-center md:text-lg opacity-90">
          Un rythme feminin et facile pour rester constante : s'hydrater, infuser, nourrir et se ressourcer.
        </p>
        <div class="mt-8 grid md:grid-cols-4 gap-4">
          <div class="rounded-2xl border border-primary/60 bg-primary/10 p-5">
            <p class="text-sm uppercase tracking-wide font-semibold text-secondary">Etape 01</p>
            <h4 class="mt-2 text-xl font-semibold">Boost du matin</h4>
            <p class="mt-2 opacity-90">Commencez par une infusion tiede et un verre d'eau pour reveiller le corps en douceur.</p>
          </div>
          <div class="rounded-2xl border border-primary/60 bg-primary/10 p-5">
            <p class="text-sm uppercase tracking-wide font-semibold text-secondary">Etape 02</p>
            <h4 class="mt-2 text-xl font-semibold">Equilibre de midi</h4>
            <p class="mt-2 opacity-90">Associez votre routine aux fruits, aux legumes verts et a 10 minutes de respiration consciente.</p>
          </div>
          <div class="rounded-2xl border border-primary/60 bg-primary/10 p-5">
            <p class="text-sm uppercase tracking-wide font-semibold text-secondary">Etape 03</p>
            <h4 class="mt-2 text-xl font-semibold">Reset du soir</h4>
            <p class="mt-2 opacity-90">Une tasse plus legere, un moment pour noter votre humeur et un sommeil regulier.</p>
          </div>
          <div class="rounded-2xl border border-primary/60 bg-primary/10 p-5">
            <p class="text-sm uppercase tracking-wide font-semibold text-secondary">Etape 04</p>
            <h4 class="mt-2 text-xl font-semibold">Point hebdomadaire</h4>
            <p class="mt-2 opacity-90">Faites le bilan de ce qui fonctionne et recevez des conseils personnalises sur WhatsApp.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="w-11/12 md:w-3/4 pb-16">
      <div class="rounded-3xl border border-primary bg-white p-8 md:p-10 shadow-lg">
        <h3 class="text-3xl md:text-4xl font-semibold text-center">Pense pour le Congo, de confiance a Johannesburg</h3>
        <p class="mt-4 text-center md:text-lg opacity-90">
          Nos conseils parlent aux realites locales : climat, rythme de vie et habitudes communautaires a Lubumbashi, Kolwezi, Kinshasa et Johannesburg.
        </p>
        <div class="mt-8 grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <div class="rounded-xl bg-primary/20 border border-primary p-4 text-center font-semibold">Lubumbashi</div>
          <div class="rounded-xl bg-primary/20 border border-primary p-4 text-center font-semibold">Kolwezi</div>
          <div class="rounded-xl bg-primary/20 border border-primary p-4 text-center font-semibold">Kinshasa</div>
          <div class="rounded-xl bg-primary/20 border border-primary p-4 text-center font-semibold">Johannesburg</div>
        </div>
      </div>
    </section>

    <section class="w-11/12 md:w-3/4 pb-20">
      <div class="rounded-3xl border border-secondary bg-gradient-to-r from-primary/60 via-white to-secondary/40 p-8 md:p-10">
        <h3 class="text-3xl md:text-4xl font-semibold text-center">Commencez votre parcours bien-etre aujourd'hui</h3>
        <p class="mt-4 text-center md:text-lg opacity-90">
          Apprenez a preparer votre infusion, structurer une routine pratique et rester reguliere avec un accompagnement fiable.
        </p>
        <div class="mt-7 flex justify-center">
          <a href={`${baseUrl}fr/contact`} class="px-8 py-3 rounded-full text-center font-semibold bg-secondary text-white shadow-lg shadow-secondary/40 hover:opacity-90 transition">
            Obtenir un accompagnement personnalise
          </a>
        </div>
      </div>
    </section>

    <section class="w-11/12 md:w-3/4 pb-24">
      <h3 class="text-3xl md:text-4xl font-semibold text-center">Ce que les femmes disent de Sante Plus</h3>
      <div class="mt-8 grid md:grid-cols-3 gap-5">
        <article class="rounded-2xl border border-secondary/60 bg-white p-6 shadow-lg">
          <p class="text-lg leading-relaxed">« Je me sens plus constante maintenant. La routine est simple, elegante et s'adapte a ma semaine chargee. »</p>
          <p class="mt-4 text-sm font-semibold uppercase tracking-wide text-secondary">Merveille • Lubumbashi</p>
        </article>
        <article class="rounded-2xl border border-secondary/60 bg-white p-6 shadow-lg">
          <p class="text-lg leading-relaxed">« Les conseils sont personnels. J'adore le ton feminin et les gestes quotidiens concrets. »</p>
          <p class="mt-4 text-sm font-semibold uppercase tracking-wide text-secondary">Grâce • Kinshasa</p>
        </article>
        <article class="rounded-2xl border border-secondary/60 bg-white p-6 shadow-lg">
          <p class="text-lg leading-relaxed">« Un design magnifique, un soutien clair et de vrais resultats grace a des habitudes saines et regulieres. »</p>
          <p class="mt-4 text-sm font-semibold uppercase tracking-wide text-secondary">Naledi • Johannesburg</p>
        </article>
      </div>
    </section>
  </main>
  <Footer data={data.footerData} lang="fr" />
</Layout>
