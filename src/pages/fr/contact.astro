---
import Layout from "@/layouts/Layout.astro";
import Footer from "@/sections/Footer.astro";
import Header from "@/sections/Header.astro";
import { getLandingData } from "@/services/data.service";

const data = await getLandingData();
---

<Layout meta={{ ...data.meta, lang: "fr", title: "Contact | Sante Plus", description: "Contactez Sante Plus pour un accompagnement bien-etre personnalise." }}>
  <Header data={data.headerData} lang="fr" />
  <main class="flex flex-col items-center pt-36 pb-16">
    <section class="w-11/12 md:w-3/4 rounded-3xl border-2 border-secondary bg-gradient-to-br from-white via-secondary/10 to-primary/10 p-8 md:p-12 shadow-xl shadow-secondary/20">
      <p class="w-fit mx-auto mb-4 rounded-full bg-secondary/15 border border-secondary px-4 py-2 text-sm font-semibold">Nous sommes la pour vous</p>
      <h1 class="text-4xl md:text-6xl font-semibold text-center">Parlons de votre routine bien-etre</h1>
      <p class="mt-6 text-center md:text-xl opacity-90">Notre equipe repond a vos questions et vous guide vers de meilleures habitudes naturelles.</p>
      <div class="mt-8 flex flex-col md:flex-row gap-4 justify-center">
        <a href="https://wa.me/243997007071" target="_blank" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl text-center font-bold bg-green-600 text-white shadow-xl shadow-green-700/40 ring-2 ring-white/70 hover:bg-green-700 transition">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.52 3.48A11.84 11.84 0 0 0 12.06 0C5.55 0 .25 5.3.25 11.81c0 2.08.55 4.12 1.6 5.93L0 24l6.45-1.7a11.78 11.78 0 0 0 5.61 1.43h.01c6.51 0 11.81-5.3 11.81-11.81 0-3.15-1.23-6.11-3.36-8.44zM12.07 21.7h-.01a9.8 9.8 0 0 1-4.99-1.37l-.36-.22-3.83 1 1.02-3.73-.24-.38a9.73 9.73 0 0 1-1.5-5.18c0-5.41 4.4-9.81 9.81-9.81 2.62 0 5.08 1.02 6.93 2.87a9.74 9.74 0 0 1 2.88 6.94c0 5.41-4.4 9.81-9.81 9.81z"></path></svg>
          Ecrire sur WhatsApp
        </a>
        <a href="https://www.instagram.com/santeplus" target="_blank" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl text-center font-bold text-white bg-gradient-to-r from-fuchsia-600 via-pink-600 to-orange-500 shadow-xl shadow-pink-600/35 ring-2 ring-white/70 hover:brightness-110 transition">
          <span class="text-lg leading-none">◎</span>
          Suivre sur Instagram
        </a>
        <a href="https://www.tiktok.com/@santeplus" target="_blank" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl text-center font-bold text-white bg-slate-900 shadow-xl shadow-slate-900/40 ring-2 ring-white/70 hover:bg-black transition">
          <span class="text-lg leading-none">♪</span>
          Suivre sur TikTok
        </a>
      </div>
    </section>

    <section class="w-11/12 md:w-3/4 mt-12 grid md:grid-cols-2 gap-8">
      <article class="rounded-2xl border border-primary bg-white p-6 shadow-md">
        <img src="https://images.unsplash.com/photo-1490818387583-1baba5e638af?auto=format&fit=crop&w=1200&q=80" alt="Infusion naturelle" class="rounded-xl h-64 w-full object-cover animated-photo" />
        <h2 class="text-2xl font-semibold mt-5">Heures de reponse</h2>
        <p class="mt-3 opacity-90">Lundi a samedi, 8h00 - 18h00 (UTC+2). Reponse rapide garantie.</p>
      </article>
      <article class="rounded-2xl border border-secondary bg-white p-6 shadow-md">
        <img src="https://images.unsplash.com/photo-1464226184884-fa280b87c399?auto=format&fit=crop&w=1200&q=80" alt="Produits et feuilles naturelles" class="rounded-xl h-64 w-full object-cover animated-photo" />
        <h2 class="text-2xl font-semibold mt-5">Conseils personnalises</h2>
        <p class="mt-3 opacity-90">Recevez des recommandations adaptees a vos objectifs et a votre rythme quotidien.</p>
      </article>
    </section>

    <section class="w-11/12 md:w-3/4 mt-10 rounded-2xl border border-secondary bg-white p-8 shadow-md">
      <h2 class="text-3xl font-semibold">Presence regionale premium</h2>
      <div class="mt-5 grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="rounded-xl border border-primary bg-primary/20 p-4">
          <p class="font-semibold">Lubumbashi</p>
          <p class="text-sm mt-1 opacity-80">Coordination principale et suivi client</p>
        </div>
        <div class="rounded-xl border border-primary bg-primary/20 p-4">
          <p class="font-semibold">Kolwezi</p>
          <p class="text-sm mt-1 opacity-80">Accompagnement communautaire</p>
        </div>
        <div class="rounded-xl border border-primary bg-primary/20 p-4">
          <p class="font-semibold">Kinshasa</p>
          <p class="text-sm mt-1 opacity-80">Conseils bien-etre urbain</p>
        </div>
        <div class="rounded-xl border border-primary bg-primary/20 p-4">
          <p class="font-semibold">Johannesburg</p>
          <p class="text-sm mt-1 opacity-80">Support transfrontalier personnalise</p>
        </div>
      </div>
    </section>

    <section class="w-11/12 md:w-3/4 mt-10 rounded-2xl border border-primary/70 bg-white/95 p-8 shadow-xl">
      <h3 class="text-3xl font-semibold text-center">Contacts directs</h3>
      <p class="mt-3 text-center md:text-lg opacity-90">
        Contactez-nous rapidement via les reseaux sociaux et WhatsApp.
      </p>
      <div class="mt-7 grid md:grid-cols-3 gap-4">
        <a href="https://www.instagram.com/santeplus" target="_blank" class="rounded-xl border-2 border-fuchsia-500 bg-gradient-to-r from-fuchsia-600 via-pink-600 to-orange-500 text-white p-4 text-center font-bold shadow-lg shadow-pink-500/35 hover:brightness-110 transition">
          Instagram: @santeplus
        </a>
        <a href="https://www.tiktok.com/@santeplus" target="_blank" class="rounded-xl border-2 border-slate-700 bg-slate-900 text-white p-4 text-center font-bold shadow-lg shadow-slate-800/35 hover:bg-black transition">
          TikTok: @santeplus
        </a>
        <a href="https://wa.me/243997007071" target="_blank" class="inline-flex items-center justify-center gap-2 rounded-xl border-2 border-green-700 bg-green-600 text-white p-4 text-center font-bold shadow-lg shadow-green-700/35 hover:bg-green-700 transition">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.52 3.48A11.84 11.84 0 0 0 12.06 0C5.55 0 .25 5.3.25 11.81c0 2.08.55 4.12 1.6 5.93L0 24l6.45-1.7a11.78 11.78 0 0 0 5.61 1.43h.01c6.51 0 11.81-5.3 11.81-11.81 0-3.15-1.23-6.11-3.36-8.44zM12.07 21.7h-.01a9.8 9.8 0 0 1-4.99-1.37l-.36-.22-3.83 1 1.02-3.73-.24-.38a9.73 9.73 0 0 1-1.5-5.18c0-5.41 4.4-9.81 9.81-9.81 2.62 0 5.08 1.02 6.93 2.87a9.74 9.74 0 0 1 2.88 6.94c0 5.41-4.4 9.81-9.81 9.81z"></path></svg>
          <span>WhatsApp: +243 997 007 071</span>
        </a>
      </div>
    </section>

    <section class="w-11/12 md:w-3/4 mt-10 rounded-3xl border border-secondary bg-gradient-to-r from-primary/55 via-white to-secondary/40 p-8 md:p-10">
      <h3 class="text-3xl md:text-4xl font-semibold text-center">Votre prochaine etape commence ici</h3>
      <p class="mt-4 text-center md:text-lg opacity-90">
        Ecrivez-nous pour recevoir une routine sur mesure, feminine, simple et adaptee a votre style de vie.
      </p>
      <div class="mt-7 flex justify-center">
        <a href="https://wa.me/243997007071" target="_blank" class="inline-flex items-center gap-2 px-8 py-3 rounded-full text-center font-semibold bg-green-600 text-white shadow-lg shadow-green-700/40 hover:bg-green-700 transition">
          <svg class="h-5 w-5 shrink-0" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <path d="M16.03 3.2C9 3.2 3.3 8.83 3.3 15.78c0 2.26.6 4.46 1.73 6.4L3.2 28.8l6.77-1.78a12.9 12.9 0 0 0 6.04 1.52h.02c7.03 0 12.73-5.64 12.73-12.6 0-3.36-1.32-6.52-3.6-8.95A12.8 12.8 0 0 0 16.03 3.2Z" fill="white"></path>
            <path d="M16.01 5.37c-5.82 0-10.55 4.68-10.55 10.44 0 2.03.6 4.02 1.72 5.72l.27.4-1.1 4.01 4.13-1.08.39.23a10.67 10.67 0 0 0 5.13 1.4h.01c5.82 0 10.55-4.68 10.55-10.44 0-2.78-1.09-5.4-3.04-7.36a10.6 10.6 0 0 0-7.5-3.32Z" fill="#25D366"></path>
            <path d="m21.98 18.69-.08-.12c-.28-.4-.98-.64-1.53-.37l-.93.47c-.25.12-.54.09-.75-.08l-.36-.28a8.16 8.16 0 0 1-1.97-2.17l-.07-.12c-.14-.24-.15-.54-.01-.78l.47-.88c.28-.52.04-1.18-.39-1.45l-.13-.08-.85-.5a1.19 1.19 0 0 0-1.64.45l-.45.76c-.94 1.6-.36 3.64.9 5.12l.33.39a11.95 11.95 0 0 0 3.42 2.69c1.57.8 3.58 1.08 5.21.12l.78-.46c.57-.34.74-1.07.4-1.62l-.52-.84Z" fill="white"></path>
          </svg>
          Demarrer ma routine
        </a>
      </div>
    </section>
  </main>
  <Footer data={data.footerData} lang="fr" />
</Layout>
