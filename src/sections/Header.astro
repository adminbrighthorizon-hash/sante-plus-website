---
import Action from "@/components/Action.astro";
import type { HeaderData } from "@/config/landing.interface";

interface Props {
  data: HeaderData;
  lang?: "en" | "fr";
}

const { data, lang = "en" } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

const navByLang = {
  en: [
    { label: "Home", href: "/" },
    { label: "Benefits", href: "/bienfaits" },
    { label: "Contact", href: "/contact" },
  ],
  fr: [
    { label: "Accueil", href: "/fr/" },
    { label: "Bienfaits", href: "/fr/bienfaits" },
    { label: "Contact", href: "/fr/contact" },
  ],
} as const;

const labels = {
  en: { nav: "Main Navigation", switchToEn: "Switch to English", switchToFr: "Switch to French" },
  fr: { nav: "Navigation principale", switchToEn: "Passer en anglais", switchToFr: "Passer en français" },
} as const;

const currentNav = navByLang[lang];
const isFr = lang === "fr";
const pathname = Astro.url.pathname;
const normalizedPath = pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;
const basePrefix = baseUrl.endsWith("/") ? baseUrl.slice(0, -1) : baseUrl;
const appPath =
  basePrefix && basePrefix !== "/" && normalizedPath.startsWith(basePrefix)
    ? normalizedPath.slice(basePrefix.length) || "/"
    : normalizedPath;
const translatedPath =
  lang === "fr"
    ? appPath.replace(/^\/fr/, "") || "/"
    : appPath === "/"
      ? "/fr"
      : `/fr${appPath}`;
const withBase = (path: string) =>
  path === "/" ? baseUrl : `${baseUrl}${path.replace(/^\/+/, "")}`;
const logoImagePath = `${baseUrl}images/logo.jpeg`;
---

<header
  id="navbar"
  class="w-full transition duration-300 justify-center fixed h-20 z-50 hidden md:flex"
>
  <nav aria-label={labels[lang].nav} class="flex flex-row items-center w-3/4">
    <div class="text-nowrap">
      <Action as="a" class="inline-flex items-center gap-2 text-xl font-semibold" href={withBase(isFr ? "/fr/" : "/")}>
        <img src={logoImagePath} alt="Sante Plus logo" class="h-10 w-10 rounded-full object-cover border border-primary/30" />
        <span>{data.logo}</span>
      </Action>
    </div>
    <ul class="flex flex-row w-full justify-center gap-x-14">
      {
        currentNav.map((item) => (
          <li class="text-lg hover:scale-110 hover:opacity-80">
            <Action as="a" href={withBase(item.href)}>
              {item.label}
            </Action>
          </li>
        ))
      }
    </ul>
    <div class="flex items-center gap-2 rounded-full border border-primary/40 bg-white/90 p-1">
      <a
        href={withBase(isFr ? translatedPath : appPath)}
        aria-label={labels[lang].switchToEn}
        class:list={[
          "rounded-full px-3 py-1 text-sm font-semibold transition inline-flex items-center gap-1",
          !isFr ? "bg-secondary text-white" : "hover:bg-primary/20",
        ]}
      >EN <span aria-hidden="true">🇬🇧</span></a>
      <a
        href={withBase(isFr ? appPath : translatedPath)}
        aria-label={labels[lang].switchToFr}
        class:list={[
          "rounded-full px-3 py-1 text-sm font-semibold transition inline-flex items-center gap-1",
          isFr ? "bg-secondary text-white" : "hover:bg-primary/20",
        ]}
      >FR <span aria-hidden="true">🇫🇷</span></a>
    </div>
  </nav>
</header>

<header
  id="mobile-navbar"
  class="fixed inset-x-0 top-0 z-50 flex h-20 items-center justify-between border-b border-transparent bg-white/90 px-4 backdrop-blur md:hidden"
>
  <Action as="a" class="inline-flex items-center gap-2 text-lg font-semibold" href={withBase(isFr ? "/fr/" : "/")}>
    <img src={logoImagePath} alt="Sante Plus logo" class="h-9 w-9 rounded-full object-cover border border-primary/30" />
    <span>{data.logo}</span>
  </Action>
  <div class="flex items-center gap-2">
    <a
      href={withBase(isFr ? translatedPath : appPath)}
      aria-label={labels[lang].switchToEn}
      class:list={[
        "rounded-full px-2.5 py-1 text-xs font-semibold transition inline-flex items-center gap-1",
        !isFr ? "bg-secondary text-white" : "bg-primary/20 text-black",
      ]}
    >EN <span aria-hidden="true">🇬🇧</span></a>
    <a
      href={withBase(isFr ? appPath : translatedPath)}
      aria-label={labels[lang].switchToFr}
      class:list={[
        "rounded-full px-2.5 py-1 text-xs font-semibold transition inline-flex items-center gap-1",
        isFr ? "bg-secondary text-white" : "bg-primary/20 text-black",
      ]}
    >FR <span aria-hidden="true">🇫🇷</span></a>
    <button
      id="mobile-menu-toggle"
      type="button"
      aria-label="Open menu"
      class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-primary/40 bg-white"
    >
      <span class="sr-only">Menu</span>
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
    </button>
  </div>
</header>

<div id="mobile-menu-overlay" class="fixed inset-0 z-40 hidden bg-black/35 md:hidden"></div>
<nav id="mobile-menu-panel" class="fixed right-0 top-0 z-50 h-full w-72 translate-x-full border-l border-primary/30 bg-white p-6 shadow-2xl transition-transform duration-300 md:hidden">
  <div class="flex items-center justify-between">
    <p class="inline-flex items-center gap-2 text-lg font-semibold">
      <img src={logoImagePath} alt="Sante Plus logo" class="h-8 w-8 rounded-full object-cover border border-primary/30" />
      <span>{data.logo}</span>
    </p>
    <button id="mobile-menu-close" type="button" aria-label="Close menu" class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-primary/30">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
    </button>
  </div>
  <ul class="mt-8 flex flex-col gap-4">
    {
      currentNav.map((item) => (
        <li>
          <Action as="a" href={withBase(item.href)} class="block rounded-xl border border-primary/30 bg-primary/10 px-4 py-3 text-base font-semibold">
            {item.label}
          </Action>
        </li>
      ))
    }
  </ul>
  <a href="https://wa.me/243997007071" target="_blank" class="mt-8 inline-flex w-full items-center justify-center gap-2 rounded-xl bg-green-600 px-4 py-3 font-semibold text-white hover:bg-green-700">
    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.52 3.48A11.84 11.84 0 0 0 12.06 0C5.55 0 .25 5.3.25 11.81c0 2.08.55 4.12 1.6 5.93L0 24l6.45-1.7a11.78 11.78 0 0 0 5.61 1.43h.01c6.51 0 11.81-5.3 11.81-11.81 0-3.15-1.23-6.11-3.36-8.44zM12.07 21.7h-.01a9.8 9.8 0 0 1-4.99-1.37l-.36-.22-3.83 1 1.02-3.73-.24-.38a9.73 9.73 0 0 1-1.5-5.18c0-5.41 4.4-9.81 9.81-9.81 2.62 0 5.08 1.02 6.93 2.87a9.74 9.74 0 0 1 2.88 6.94c0 5.41-4.4 9.81-9.81 9.81z"></path></svg>
    WhatsApp
  </a>
</nav>

<script>
  const toggleScrolled = () => {
    const navbar = document.getElementById("navbar");
    const mobileNavbar = document.getElementById("mobile-navbar");

    if (window.scrollY >= 20) {
      navbar?.classList.remove("border-b-transparent", "bg-transparent");
      navbar?.classList.add("border-b", "border-b-primary", "bg-white/90");
      mobileNavbar?.classList.remove("border-transparent");
      mobileNavbar?.classList.add("border-primary");
    } else {
      navbar?.classList.remove("border-b", "border-b-primary", "bg-white/90");
      navbar?.classList.add("border-b-transparent", "bg-transparent");
      mobileNavbar?.classList.remove("border-primary");
      mobileNavbar?.classList.add("border-transparent");
    }
  };

  window.addEventListener("scroll", toggleScrolled);
  toggleScrolled();

  const menuToggle = document.getElementById("mobile-menu-toggle");
  const menuClose = document.getElementById("mobile-menu-close");
  const menuPanel = document.getElementById("mobile-menu-panel");
  const menuOverlay = document.getElementById("mobile-menu-overlay");

  const openMenu = () => {
    menuPanel?.classList.remove("translate-x-full");
    menuOverlay?.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  };

  const closeMenu = () => {
    menuPanel?.classList.add("translate-x-full");
    menuOverlay?.classList.add("hidden");
    document.body.style.overflow = "";
  };

  menuToggle?.addEventListener("click", openMenu);
  menuClose?.addEventListener("click", closeMenu);
  menuOverlay?.addEventListener("click", closeMenu);

  menuPanel?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });
</script>
