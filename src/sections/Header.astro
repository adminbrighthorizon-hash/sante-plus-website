---
import Action from "@/components/Action.astro";
import type { HeaderData } from "@/config/landing.interface";

interface Props {
  data: HeaderData;
  lang?: "en" | "fr";
}

const { data, lang = "en" } = Astro.props;

const navByLang = {
  en: [
    { label: "Home", href: "/" },
    { label: "Benefits", href: "/bienfaits" },
    { label: "Contact", href: "/contact" },
  ],
  fr: [
    { label: "Accueil", href: "/fr/" },
    { label: "Bienfaits", href: "/fr/bienfaits" },
    { label: "Contact", href: "/fr/contact" },
  ],
} as const;

const labels = {
  en: { nav: "Main Navigation", switchToEn: "Switch to English", switchToFr: "Switch to French" },
  fr: { nav: "Navigation principale", switchToEn: "Passer en anglais", switchToFr: "Passer en français" },
} as const;

const currentNav = navByLang[lang];
const isFr = lang === "fr";
const pathname = Astro.url.pathname;
const normalizedPath = pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;
const translatedPath =
  lang === "fr"
    ? normalizedPath.replace(/^\/fr/, "") || "/"
    : normalizedPath === "/"
      ? "/fr"
      : `/fr${normalizedPath}`;
---

<header
  id="navbar"
  class="w-full transition duration-300 justify-center fixed h-20 z-50 hidden md:flex"
>
  <nav aria-label={labels[lang].nav} class="flex flex-row items-center w-3/4">
    <div class="text-nowrap">
      <Action as="a" class="text-xl font-semibold" href={isFr ? "/fr/" : "/"}>{data.logo}</Action>
    </div>
    <ul class="flex flex-row w-full justify-center gap-x-14">
      {
        currentNav.map((item) => (
          <li class="text-lg hover:scale-110 hover:opacity-80">
            <Action as="a" href={item.href}>
              {item.label}
            </Action>
          </li>
        ))
      }
    </ul>
    <div class="flex items-center gap-2 rounded-full border border-primary/40 bg-white/90 p-1">
      <a
        href={isFr ? translatedPath : normalizedPath}
        aria-label={labels[lang].switchToEn}
        class:list={[
          "rounded-full px-3 py-1 text-sm font-semibold transition",
          !isFr ? "bg-secondary text-white" : "hover:bg-primary/20",
        ]}
      >
        EN
      </a>
      <a
        href={isFr ? normalizedPath : translatedPath}
        aria-label={labels[lang].switchToFr}
        class:list={[
          "rounded-full px-3 py-1 text-sm font-semibold transition",
          isFr ? "bg-secondary text-white" : "hover:bg-primary/20",
        ]}
      >
        FR
      </a>
    </div>
  </nav>
</header>

<script>
  window.addEventListener("scroll", function () {
    const navbar = document.getElementById("navbar");
    if (!navbar) return;

    if (window.scrollY >= 20) {
      navbar.classList.remove("border-b-transparent");
      navbar.classList.remove("bg-transparent");
      navbar.classList.add("border-b");
      navbar.classList.add("border-b-primary");
      navbar.classList.add("bg-white/90");
    } else {
      navbar.classList.remove("border-b");
      navbar.classList.remove("border-b-primary");
      navbar.classList.remove("bg-white/90");
      navbar.classList.add("border-b-transparent");
      navbar.classList.add("bg-transparent");
    }
  });
</script>
