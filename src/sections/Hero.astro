---
import Action from "@/components/Action.astro";

interface Props {
  data: {
    title: string;
    subTitle: string;
    primaryCta: string;
    secondaryCta: string;
    highlightedTitle?: string;
  };
}

const { data } = Astro.props;
---

<section id="hero-section" class="flex justify-center mt-44 min-h-screen">
  <div class="md:w-2/3 rounded-3xl border border-primary/70 bg-white/80 backdrop-blur-sm px-6 py-10 md:px-12">
    <p class="mx-auto mb-6 w-fit rounded-full border border-secondary bg-primary/60 px-4 py-2 text-sm font-medium">
      Bien-être naturel de confiance
    </p>
    <h1 class="text-4xl text-center font-semibold md:text-6xl leading-tight">
      {data.title}
      <span class="text-secondary"> {data.highlightedTitle} </span>
    </h1>
    <h2 class="mt-8 text-lg text-center opacity-80 md:text-2xl">
      {data.subTitle}
    </h2>
    <div class="flex flex-col md:flex-row gap-4 justify-center mt-10">
      <Action
        as="a"
        type="button"
        class="bg-secondary text-white shadow-lg shadow-secondary/40"
        href="https://wa.me/243997007071"
        target="_blank"
      >
        {data.primaryCta}
      </Action>
      <Action
        as="a"
        class="bg-white text-black border border-secondary"
        type="button"
        href="#services-section"
      >
        {data.secondaryCta}
      </Action>
    </div>
    <div class="flex justify-center">
      <Action
        as="a"
        class="flex justify-center items-center animate-bounce border-2 border-secondary bg-primary text-black rounded-full w-14 h-14 mt-16 hover:bg-white hover:text-black hover:border-secondary transition"
        href="#services-section"
        title="arrow down icon"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="w-8 h-8"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3"></path>
        </svg>
      </Action>
    </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  #hero-section {
    opacity: 0;
    animation: fadeIn 0.8s ease-in-out forwards;
  }
</style>
